APP_NAME=Laravel
APP_ENV=local
APP_KEY=GERAR_NO_LARAVEL
APP_DEBUG=true
APP_URL=http://127.0.0.1

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=SUA_DATABASE
DB_USERNAME=SEU_USERNAME
DB_PASSWORD=SUA_SENHA

# Sessão em arquivo é mais leve que DB
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Cache em arquivo por enquanto
CACHE_DRIVER=file
CACHE_STORE=file

# Queue síncrona em dev
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=SEU_FRONTEND:PORTA
SESSION_DOMAIN=localhost

SANCTUM_EXPIRATION = 60